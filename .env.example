APP_APP_NAME=speech-to-speech-backend
APP_APP_ENV=development
APP_STORAGE_ROOT=.data
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/speech_to_speech
APP_FFMPEG_COMMAND=tools/bin/ffmpeg/ffmpeg-8.1-essentials_build/bin/ffmpeg.exe
APP_FFMPEG_TIMEOUT_SECONDS=30
APP_ASR_COMMAND=tools/bin/whisper/Release/whisper-cli.exe
APP_ASR_MODEL_PATH=models/ggml-base.en.bin
APP_ASR_LANGUAGE=en
APP_ASR_TIMEOUT_SECONDS=120
APP_TTS_COMMAND=tools/bin/piper/piper/piper.exe
APP_TTS_MODEL_PATH=models/en_US-lessac-medium.onnx
APP_TTS_CONFIG_PATH=models/en_US-lessac-medium.onnx.json
APP_TTS_VOICE_MODELS_JSON={"lessac":"models/en_US-lessac-medium.onnx","amy":"models/en_US-amy-medium.onnx","ryan":"models/en_US-ryan-medium.onnx"}
APP_TTS_VOICE_CONFIGS_JSON={"lessac":"models/en_US-lessac-medium.onnx.json","amy":"models/en_US-amy-medium.onnx.json","ryan":"models/en_US-ryan-medium.onnx.json"}
APP_TTS_TIMEOUT_SECONDS=60